{
  "name": "clear-writer-app",
  "private": true,
  "version": "0.1.0",
  "description": "Clear Writer is a focused document editor and PDF exporter.",
  "author": "Clear Writer Contributors",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.web.config.ts",
    "dev:web": "vite --config vite.web.config.ts",
    "build": "tsc && vite build --config vite.web.config.ts",
    "build:web": "tsc && vite build --config vite.web.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test --test-concurrency=1 test/*.test.cjs",
    "test:perf": "node --test --test-concurrency=1 test/*.perf.cjs",
    "test:browser-smoke": "node scripts/release-browser-smoke.mjs",
    "test:pwa-smoke": "npm run build && node scripts/release-web-shell-smoke.mjs",
    "release:prep": "npm test && npm run test:perf && npm run test:browser-smoke && npm run test:pwa-smoke",
    "profile:preview": "node --expose-gc scripts/profile-preview.mjs",
    "profile:pagination": "node scripts/profile-pagination.mjs",
    "preview": "vite preview --outDir dist-web",
    "postinstall": "node patch-pagedjs.js"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "jszip": "^3.10.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/inter-tight": "^5.2.7",
    "@lezer/highlight": "^1.2.3",
    "codemirror": "^6.0.2",
    "morphdom": "^2.7.8",
    "pagedjs": "^0.4.3",
    "docx": "^8.5.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  }
}
